# Backend environment — copy to .env and fill in.

# Server
PORT=3000

# Database (Prisma) — points at the database/ package's Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/accountability_coach?schema=public

# Anthropic Claude API (LLM tiers — doc 09 §5). Zero-retention agreement in prod.
ANTHROPIC_API_KEY=

# Expo Push (server-initiated notifications via the Outbound Governor — doc 09 §6)
EXPO_ACCESS_TOKEN=
